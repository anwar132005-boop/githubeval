pipeline {
    agent any

    stages {

        stage('Install Docker') {
            steps {
                sh '''
                    sudo apt update

                    sudo apt install -y \
                        apt-transport-https \
                        ca-certificates \
                        curl \
                        software-properties-common

                    sudo apt install -y docker.io

                    sudo systemctl enable docker
                    sudo systemctl start docker

                    sudo usermod -aG docker $USER

                    docker --version
                '''
            }
        }

    }
}
