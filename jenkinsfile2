pipeline {
    agent any

    stages {
        stage('Install Docker') {
            steps {
                script {
                    // Vérifier si Docker est déjà installé
                    def dockerExists = sh(script: 'command -v docker', returnStatus: true) == 0
                    
                    if (!dockerExists) {
                        sh '''
                            # Utiliser expect ou passer par un script shell avec gestion d'erreur
                            echo 'Installing Docker...'
                        '''
                        
                        // Alternative : utiliser apt-get sans sudo (si Jenkins est root - non recommandé)
                        // Ou mieux : utiliser Docker pipeline plugin
                    }
                }
                
                // Si vous devez absolument utiliser sudo, faites-le comme ceci :
                sh 'echo "password" | sudo -S apt update'  # Pas sécurisé!
            }
        }
    }
}
